# Saferide web app (Next.js) — copy to `.env` or `.env.local` and fill in secrets.

# Required for Gemini / Google GenAI calls (get a key from Google AI Studio).
GEMINI_API_KEY=

# Public site URL (local dev or deployed). Used for links, callbacks, and API base resolution.
APP_URL=http://localhost:3000

# Backend API base URL (optional; use when the UI calls the FastAPI service).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional: stable origin for QR codes / printed badges (defaults to current browser origin).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to `true` to reduce HMR churn when an external agent edits files (see next.config.ts).
DISABLE_HMR=false

# Saferide API — copy to `.env`. Loaded from `backend/` by `app.core.config`.

# --- Core ---
APP_NAME=Saferide API
ENVIRONMENT=local
DEBUG=true

DATABASE_URL=sqlite:///./saferide.db
API_V1_PREFIX=/api/v1

SECRET_KEY=replace-with-a-long-random-secret-in-production
# Optional alias: JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Optional alias: JWT_ACCESS_EXPIRES_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=30
# Optional alias: JWT_REFRESH_EXPIRES_DAYS=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

HOST=127.0.0.1
PORT=8000
ADMIN_BOOTSTRAP_SECRET=change-this-for-dev-bootstrap

# Next.js URL for post–eSignet redirect (token sent in URL #fragment)
FRONTEND_APP_URL=http://localhost:3000
# Comma-separated paths allowed for /auth/esignet/login?next=
OAUTH_NEXT_PATH_ALLOWLIST=/,/driver/profile,/portal,/admin,/login,/verify,/how-it-works,/privacy,/report,/offline,/simulate/ussd,/simulate/sms,/driver/consent

# Simulated panic SMS recipients (comma MSISDNs) — used by POST /public/emergency/share
SIM_EMERGENCY_SMS_RECIPIENTS=+255700000001,+255700000002

# Consent / disclosure token TTLs (minutes)
CONSENT_REQUEST_TTL_MINUTES=15
DISCLOSURE_TOKEN_TTL_MINUTES=60

# --- MOSIP eSignet (OIDC) — point at your running eSignet instance ---
ESIGNET_BASE_URL=http://localhost:8088
ESIGNET_ISSUER=http://localhost:8088
ESIGNET_AUTHORIZATION_ENDPOINT=http://localhost:8088/authorize
ESIGNET_TOKEN_ENDPOINT=http://localhost:8088/v1/esignet/oauth/v2/token
ESIGNET_USERINFO_ENDPOINT=http://localhost:8088/v1/esignet/oidc/userinfo
ESIGNET_JWKS_URI=http://localhost:8088/.well-known/jwks.json
ESIGNET_WELLKNOWN_URL=http://localhost:8088/.well-known/openid-configuration

ESIGNET_CLIENT_ID=
APP_BASE_URL=http://localhost:8000
ESIGNET_REDIRECT_URI=http://localhost:8000/auth/esignet/callback
ESIGNET_SCOPES=openid profile email phone
ESIGNET_ACR_VALUES=
ESIGNET_VCI_OTP=111111
ESIGNET_VCI_OTP_CHANNELS=email,phone

# PEM paths (private key for token endpoint client assertion; public key to verify userinfo JWT)
ESIGNET_PRIVATE_KEY_PATH=./keys/esignet_private.pem
ESIGNET_PRIVATE_KEY_KID=
ESIGNET_CLIENT_ASSERTION_ALG=RS256
ESIGNET_PUBLIC_KEY_PATH=./keys/esignet_public.pem
MOCK_IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5455/mosip_mockidentitysystem

# --- Inji Certify (VC issuance) ---
INJI_CERTIFY_ENABLE=false
INJI_CERTIFY_BASE_URL=http://127.0.0.1:8090
INJI_CERTIFY_IDENTIFIER=http://certify-nginx:80
INJI_CERTIFY_API_KEY=
INJI_CERTIFY_ISSUER_ID=SafeRide
INJI_CERTIFY_TIMEOUT=30
INJI_CERTIFY_OPERATOR_CREDENTIAL_TEMPLATE=SafeRideDriverCredential
INJI_CERTIFY_VEHICLE_CREDENTIAL_TEMPLATE=SafeRideVehicleBindingCredential
INJI_CERTIFY_OPERATOR_ISSUE_PATH=/v1/certify/issuance/credential
INJI_CERTIFY_VEHICLE_ISSUE_PATH=/v1/certify/issuance/credential
INJI_CERTIFY_CREDENTIAL_ISSUER_PATH=/v1/certify
INJI_WEB_BASE_URL=http://localhost:3004
